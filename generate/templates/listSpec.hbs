import { TestBed, ComponentFixture } from '@angular/core/testing';
import { By } from '@angular/platform-browser';
import { {{capitalize nameLower}}ListPageComponent } from './{{nameLower}}-list-page.component';
import { {{capitalize nameLower}}Service } from './{{nameLower}}.service';
import { AuthService } from '../../core/services/auth.service';
import { ToastService } from '../../core/services/toast.service';
import { Router } from '@angular/router';
import { of, throwError } from 'rxjs';
import { vi } from 'vitest';

describe('{{capitalize nameLower}}ListPageComponent', () => {
  let component: {{capitalize nameLower}}ListPageComponent;
  let fixture: ComponentFixture<{{capitalize nameLower}}ListPageComponent>;
  let mockService: any;
  let mockAuthService: any;
  let mockToastService: any;
  let mockRouter: any;

  const mockItems = [
    { id: '1', name: 'Item 1', active: true },
  ];

  beforeEach(async () => {
    mockService = {
      get{{capitalize nameLower}}s: vi.fn().mockReturnValue(of({ items: mockItems, total: 1 })),
      toggleStatus: vi.fn().mockReturnValue(of({})),
      delete{{capitalize nameLower}}: vi.fn().mockReturnValue(of({})),
    };

    mockAuthService = {
      hasPermission: vi.fn().mockReturnValue(true),
    };

    mockToastService = {
      success: vi.fn(),
      error: vi.fn(),
    };

    mockRouter = {
      navigate: vi.fn().mockResolvedValue(true),
    };

    await TestBed.configureTestingModule({
      imports: [{{capitalize nameLower}}ListPageComponent],
      providers: [
        { provide: {{capitalize nameLower}}Service, useValue: mockService },
        { provide: AuthService, useValue: mockAuthService },
        { provide: ToastService, useValue: mockToastService },
        { provide: Router, useValue: mockRouter },
      ],
    }).compileComponents();

    fixture = TestBed.createComponent({{capitalize nameLower}}ListPageComponent);
    component = fixture.componentInstance;
  });

  it('should create and load items', async () => {
    fixture.detectChanges();
    await fixture.whenStable();
    
    expect(component.items()).toEqual(mockItems);
    expect(mockService.get{{capitalize nameLower}}s).toHaveBeenCalled();
  });

  it('should handle search', () => {
    fixture.detectChanges();
    component.handleSearch('test');
    expect(component.searchWord()).toBe('test');
    expect(component.page()).toBe(0);
  });

  it('should handle filters', () => {
    fixture.detectChanges();
    component.handleFilter({ active: 'true' });
    expect(component.filters()).toEqual({ active: 'true' });
    expect(component.page()).toBe(0);
  });

  it('should handle page change', () => {
    fixture.detectChanges();
    component.handlePageChange(2);
    expect(component.page()).toBe(2);
  });

  it('should toggle filter drawer', () => {
    fixture.detectChanges();
    component.toggleFilter();
    expect(component.isFilterOpen()).toBe(true);
    component.toggleFilter();
    expect(component.isFilterOpen()).toBe(false);
  });

  it('should navigate to create', () => {
    component.navigateToCreate();
    expect(mockRouter.navigate).toHaveBeenCalledWith(['/{{nameLower}}s/new']);
  });

  it('should navigate to edit', () => {
    component.navigateToEdit('1');
    expect(mockRouter.navigate).toHaveBeenCalledWith(['/{{nameLower}}s/update', '1']);
  });

  it('should toggle status successfully', async () => {
    fixture.detectChanges();
    await component.toggleStatus('1', false);
    expect(mockService.toggleStatus).toHaveBeenCalledWith('1', false);
    expect(mockToastService.success).toHaveBeenCalled();
  });

  it('should delete item successfully', async () => {
    fixture.detectChanges();
    await component.deleteItem('1');
    expect(mockService.delete{{capitalize nameLower}}).toHaveBeenCalledWith('1');
    expect(mockToastService.success).toHaveBeenCalled();
  });

  it('should handle error loading items', async () => {
    mockService.get{{capitalize nameLower}}s.mockReturnValue(throwError(() => new Error('Error')));
    fixture.detectChanges();
    await fixture.whenStable();
    expect(mockToastService.error).toHaveBeenCalled();
  });

  it('should trigger events from template', () => {
    fixture.detectChanges();
    const header = fixture.debugElement.query(By.css('app-list-page-header'));
    
    header.triggerEventHandler('onSearch', 'search');
    expect(component.searchWord()).toBe('search');

    header.triggerEventHandler('onFilterClick', null);
    expect(component.isFilterOpen()).toBe(true);

    header.triggerEventHandler('onCreateClick', null);
    expect(mockRouter.navigate).toHaveBeenCalled();
  });

  it('should render items correctly in table', async () => {
    fixture.detectChanges();
    await fixture.whenStable();
    fixture.detectChanges();
    
    const compiled = fixture.nativeElement;
    expect(compiled.querySelector('app-status-badge')).toBeTruthy();
    expect(compiled.querySelector('app-data-table-actions')).toBeTruthy();
    expect(compiled.textContent).toContain('Item 1');
  });

  it('should trigger actions from template', async () => {
    fixture.detectChanges();
    await fixture.whenStable();
    fixture.detectChanges();

    const actions = fixture.debugElement.query(By.css('app-data-table-actions')).componentInstance;
    
    actions.onEdit.emit('1');
    expect(mockRouter.navigate).toHaveBeenCalledWith(['/{{nameLower}}s/update', '1']);

    actions.onDelete.emit('1');
    expect(mockService.delete{{capitalize nameLower}}).toHaveBeenCalledWith('1');

    const badge = fixture.debugElement.query(By.css('app-status-badge')).componentInstance;
    badge.onClick.emit();
    expect(mockService.toggleStatus).toHaveBeenCalled();
  });

  it('should trigger table events from template', () => {
    fixture.detectChanges();
    const table = fixture.debugElement.query(By.css('app-data-table'));
    
    table.triggerEventHandler('onPageChange', 1);
    expect(component.page()).toBe(1);

    table.triggerEventHandler('onPageSizeChange', 50);
    expect(component.size()).toBe(50);

    const sort = { orderBy: 'name', orderDirection: 'desc' };
    table.triggerEventHandler('onSortChange', sort);
    expect(component.sort()).toEqual(sort);
  });

  it('should call helper methods for funcs coverage', () => {
    component.loadItems();
    expect(true).toBe(true);
  });
});
